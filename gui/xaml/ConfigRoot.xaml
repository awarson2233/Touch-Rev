<Grid
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F01E1E1E">

    <StackPanel Margin="24" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <!-- 标题区域 -->
        <StackPanel Margin="0,10,0,25" HorizontalAlignment="Center">
            <TextBlock 
                Text="Touch-Rev 控制中心" 
                FontSize="20" 
                FontWeight="SemiBold" 
                Foreground="White" 
                HorizontalAlignment="Center"/>
            <TextBlock 
                Text="定制与优化您的 Windows 手势体验" 
                FontSize="12" 
                Foreground="#80FFFFFF" 
                Margin="0,4,0,0"
                HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 设置项卡片 -->
        <Border Background="#1CFFFFFF" CornerRadius="8" Padding="16,10,16,16" Margin="0,0,0,16">
            <StackPanel Spacing="14">
                <ToggleSwitch 
                    x:Name="HookToggle" 
                    Header="系统手势 Hook 拦截" 
                    Foreground="White" 
                    OffContent="拦截已关闭" 
                    OnContent="拦截已开启"
                    IsOn="False"/>
                <TextBlock 
                    Text="拦截 Win10/11 默认的三四指手势以防冲突" 
                    FontSize="11" 
                    Foreground="#80FFFFFF" 
                    Margin="0,-6,0,0"/>
            </StackPanel>
        </Border>

        <Border Background="#1CFFFFFF" CornerRadius="8" Padding="16,10,16,16" Margin="0,0,0,16">
            <StackPanel Spacing="14">
                <ToggleSwitch 
                    x:Name="GestureToggle" 
                    Header="自定义手势识别" 
                    Foreground="White" 
                    OffContent="手势识别已禁用" 
                    OnContent="手势识别已启用"
                    IsOn="True"/>
                <TextBlock 
                    Text="启用此程序自定义的三指滑动和长按触发手势" 
                    FontSize="11" 
                    Foreground="#80FFFFFF" 
                    Margin="0,-6,0,0"/>
            </StackPanel>
        </Border>

        <Border Background="#1CFFFFFF" CornerRadius="8" Padding="16,10,16,16" Margin="0,0,0,25">
            <StackPanel Spacing="14">
                <ToggleSwitch 
                    x:Name="WindowToggle" 
                    Header="启用任务切换卡片窗口" 
                    Foreground="White" 
                    OffContent="切换窗口已禁用" 
                    OnContent="切换窗口已启用"
                    IsOn="True"/>
                <TextBlock 
                    Text="触发手势时弹出三维视感任务切换界面" 
                    FontSize="11" 
                    Foreground="#80FFFFFF" 
                    Margin="0,-6,0,0"/>
            </StackPanel>
        </Border>

        <!-- 按钮区域 -->
        <Button 
            x:Name="ExitButton" 
            Content="退出应用" 
            HorizontalAlignment="Stretch" 
            Height="38" 
            Background="#D63A3A3A" 
            Foreground="White" 
            BorderBrush="#33FFFFFF"
            BorderThickness="1"
            CornerRadius="4"/>
    </StackPanel>
</Grid>
