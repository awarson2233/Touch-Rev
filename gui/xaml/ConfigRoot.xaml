<Grid
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ControlFillColorTransparentBrush}">

    <!-- 内容区域 -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,20,28,24" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <!-- 标题区域 -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 齿轮配置大图标底盘 -->
                <Border Grid.Column="0"
                        Width="44"
                        Height="44"
                        CornerRadius="10"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        Margin="0,0,16,0"
                        VerticalAlignment="Center">
                    <FontIcon FontFamily="Segoe MDL2 Assets"
                              Glyph="&#xE713;"
                              FontSize="20"
                              Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock
                        Text="Touch-Rev 控制中心"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock
                        Text="定制与优化您的 Windows 触控手势体验"
                        FontSize="11.5"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Margin="0,1,0,0"/>
                </StackPanel>
            </Grid>

            <!-- 设置项 1: Hook 拦截 -->
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,14,16,14"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 图标底圈 -->
                    <Border Grid.Column="0"
                            Width="40"
                            Height="40"
                            CornerRadius="20"
                            Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE72E;"
                                  FontSize="18"
                                  Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="系统手势 Hook 拦截"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="拦截 Windows 默认的三四指触控手势，防止与自定义手势冲突"
                                   FontSize="11.5"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,3,0,4"/>
                        <!-- 运行状态指示器 -->
                        <TextBlock x:Name="HookStatusText"
                                   Text="运行状态：未知"
                                   FontSize="11"
                                   FontWeight="Medium"/>
                    </StackPanel>

                    <ToggleSwitch x:Name="HookToggle"
                                  Grid.Column="2"
                                  VerticalAlignment="Center"
                                  IsOn="False"/>
                </Grid>
            </Border>

            <!-- 设置项 2: 自定义手势 -->
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,14,16,14"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 图标底圈 -->
                    <Border Grid.Column="0"
                            Width="40"
                            Height="40"
                            CornerRadius="20"
                            Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE815;"
                                  FontSize="18"
                                  Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="自定义手势识别"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="启用本程序自定义的三指滑动与三指长按触发手势"
                                   FontSize="11.5"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <ToggleSwitch x:Name="GestureToggle"
                                  Grid.Column="2"
                                  VerticalAlignment="Center"
                                  IsOn="True"/>
                </Grid>
            </Border>

            <!-- 设置项 3: 任务切换卡片 -->
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,14,16,14"
                    Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 图标底圈 -->
                    <Border Grid.Column="0"
                            Width="40"
                            Height="40"
                            CornerRadius="20"
                            Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE8A7;"
                                  FontSize="18"
                                  Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="启用任务切换卡片窗口"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="触发手势时弹出三维视觉任务卡片切换界面"
                                   FontSize="11.5"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <ToggleSwitch x:Name="WindowToggle"
                                  Grid.Column="2"
                                  VerticalAlignment="Center"
                                  IsOn="True"/>
                </Grid>
            </Border>

            <!-- 退出应用按钮 -->
            <Button
                x:Name="ExitButton"
                Content="完全退出应用程序"
                HorizontalAlignment="Stretch"
                Height="38"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                FontWeight="SemiBold"/>
        </StackPanel>
    </ScrollViewer>
</Grid>
