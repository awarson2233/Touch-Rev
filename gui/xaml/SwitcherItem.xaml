<Grid
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="RootGrid"
    Background="Transparent"
    RenderTransformOrigin="0.5,0.5">
    <Grid.Resources>
        <x:Double x:Key="PressedScale">0.985</x:Double>
        <x:Double x:Key="GrabbedScale">0.90</x:Double>
    </Grid.Resources>
    <Grid.RenderTransform>
        <CompositeTransform x:Name="ItemTransform" />
    </Grid.RenderTransform>

    <Border
        x:Name="MainCard"
        Background="{ThemeResource CardBackgroundBrush}"
        CornerRadius="10">
        <Grid x:Name="ItemLayoutGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.8*" />
                <RowDefinition Height="8.2*" />
            </Grid.RowDefinitions>

            <Border
                x:Name="TitleBorder"
                Grid.Row="0"
                Background="{ThemeResource TitleBackgroundBrush}"
                BorderThickness="0"
                CornerRadius="10,10,0,0">
                <Grid x:Name="TitleGrid" Padding="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid
                        Grid.Column="0"
                        Margin="12,0,8,0"
                        VerticalAlignment="Center">
                        <Image
                            x:Name="AppIcon"
                            Width="16"
                            Height="16"
                            Stretch="Uniform"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed" />
                        <TextBlock
                            x:Name="DefaultIcon"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="14"
                            Foreground="{ThemeResource IconTextBrush}"
                            Text="&#xE700;"
                            Visibility="Visible" />
                    </Grid>

                    <TextBlock
                        x:Name="TitleText"
                        Grid.Column="1"
                        Margin="4,0,4,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{ThemeResource PrimaryTextBrush}"
                        TextTrimming="CharacterEllipsis" />

                    <Button
                        x:Name="CloseButton"
                        Grid.Column="2"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        BorderThickness="0"
                        Content="&#xE106;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="10">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonForeground" Color="{ThemeResource ButtonTextColor}" />
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{ThemeResource CloseButtonHoverBackgroundColor}" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{ThemeResource CloseButtonHoverTextColor}" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{ThemeResource CloseButtonHoverBackgroundColor}" />
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{ThemeResource CloseButtonHoverTextColor}" />
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>

            <Border
                x:Name="ContentFrame"
                Grid.Row="1"
                Margin="0"
                Background="{ThemeResource ContentBackgroundBrush}"
                BorderThickness="0"
                CornerRadius="0,0,10,10">
                <Grid>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="#66FFFFFF"
                        Text="ThumbnailHost" />
                </Grid>
            </Border>

            <Border
                x:Name="PressOverlay"
                Grid.RowSpan="2"
                Background="{ThemeResource CardPressedOverlayBrush}"
                CornerRadius="10"
                IsHitTestVisible="False"
                Visibility="Collapsed" />
        </Grid>
    </Border>
</Grid>
