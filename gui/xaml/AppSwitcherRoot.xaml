<Grid
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="RootGrid"
    Background="{ThemeResource ControlFillColorTransparentBrush}">

    <Grid.Resources>
        <ResourceDictionary>
            <x:Double x:Key="PaddingDip">48</x:Double>
            <x:Double x:Key="ItemGapDip">32</x:Double>
            <x:Double x:Key="MinAspect">0.4</x:Double>
            <x:Double x:Key="MaxAspect">2.5</x:Double>
        </ResourceDictionary>
    </Grid.Resources>

    <Canvas x:Name="LayoutCanvas">

        <Border
            x:Name="AppSwitcherContainer"
            Canvas.ZIndex="1"
            Background="{ThemeResource ControlFillColorTransparentBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12" />

        <Border
            x:Name="FocusBorder"
            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
            BorderThickness="4"
            Canvas.ZIndex="2"
            CornerRadius="20"
            IsHitTestVisible="False"
            Visibility="Collapsed"
            Background="{ThemeResource AccentFillColorSecondaryBrush}">
            <Border.Resources>
                <x:Double x:Key="InflationDip">10</x:Double>
            </Border.Resources>
        </Border>
    </Canvas>

    <Grid
        x:Name="EmptyGrid"
        Padding="40"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Visibility="Collapsed">
        <StackPanel>
            <TextBlock
                x:Name="EmptyIcon"
                HorizontalAlignment="Center"
                FontFamily="Segoe MDL2 Assets"
                FontSize="48"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="&#xE119;" />
            <TextBlock
                x:Name="EmptyText"
                Margin="0,12,0,0"
                HorizontalAlignment="Center"
                FontSize="18"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="No switchable windows" />
        </StackPanel>
    </Grid>
</Grid>
