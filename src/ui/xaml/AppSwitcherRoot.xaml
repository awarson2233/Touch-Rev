<Grid
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="RootGrid"
    Background="Transparent">

    <Canvas x:Name="LayoutCanvas">
        <Border
            x:Name="AppSwitcherContainer"
            Canvas.ZIndex="0"
            Background="#CC181818"
            BorderBrush="#55FFFFFF"
            BorderThickness="1"
            CornerRadius="24" />

        <Border
            x:Name="FocusBorder"
            BorderBrush="#FF4CC2FF"
            BorderThickness="4"
            Canvas.ZIndex="100"
            CornerRadius="20"
            IsHitTestVisible="False"
            Visibility="Collapsed"
            Background="#224CC2FF" />
    </Canvas>

    <Grid
        x:Name="EmptyGrid"
        Padding="40"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Visibility="Collapsed">
        <StackPanel>
            <TextBlock
                x:Name="EmptyIcon"
                HorizontalAlignment="Center"
                FontFamily="Segoe MDL2 Assets"
                FontSize="48"
                Foreground="#88FFFFFF"
                Text="&#xE119;" />
            <TextBlock
                x:Name="EmptyText"
                Margin="0,12,0,0"
                HorizontalAlignment="Center"
                FontSize="18"
                Foreground="#CCFFFFFF"
                Text="No switchable windows" />
        </StackPanel>
    </Grid>
</Grid>
