<Grid
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="RootGrid"
    Background="Transparent"
    RenderTransformOrigin="0.5,0.5">
    <Grid.RenderTransform>
        <CompositeTransform x:Name="ItemTransform" />
    </Grid.RenderTransform>

    <Border
        x:Name="MainCard"
        Background="#EE242424"
        CornerRadius="10">
        <Grid x:Name="ItemLayoutGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.6*" />
                <RowDefinition Height="8.4*" />
            </Grid.RowDefinitions>

            <Border
                x:Name="TitleBorder"
                Grid.Row="0"
                Background="#F0303030"
                BorderThickness="0"
                CornerRadius="10,10,0,0">
                <Grid x:Name="TitleGrid" Padding="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid
                        Grid.Column="0"
                        Margin="12,0,8,0"
                        VerticalAlignment="Center">
                        <Image
                            x:Name="AppIcon"
                            Width="16"
                            Height="16"
                            Stretch="Uniform"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed" />
                        <TextBlock
                            x:Name="DefaultIcon"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="14"
                            Foreground="#CCFFFFFF"
                            Text="&#xE700;"
                            Visibility="Visible" />
                    </Grid>

                    <TextBlock
                        x:Name="TitleText"
                        Grid.Column="1"
                        Margin="4,0,4,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#FFFFFFFF"
                        TextTrimming="CharacterEllipsis" />

                    <Button
                        x:Name="CloseButton"
                        Grid.Column="2"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Content="&#xE106;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="10"
                        Foreground="#CCFFFFFF" />
                </Grid>
            </Border>

            <Border
                x:Name="ContentFrame"
                Grid.Row="1"
                Margin="0"
                Background="#FF101010"
                BorderThickness="0"
                CornerRadius="0,0,10,10">
                <Grid>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="#66FFFFFF"
                        Text="ThumbnailHost" />
                </Grid>
            </Border>

            <Border
                x:Name="PressOverlay"
                Grid.RowSpan="2"
                Background="#22000000"
                CornerRadius="10"
                IsHitTestVisible="False"
                Visibility="Collapsed" />
        </Grid>
    </Border>
</Grid>
