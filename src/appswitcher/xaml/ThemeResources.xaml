<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
            <!-- 亚克力及窗口全局 -->
            <Color x:Key="AcrylicTintColor">#FF202020</Color>
            <x:Double x:Key="AcrylicBlurAmount">80</x:Double>
            <x:Double x:Key="AcrylicNoiseOpacity">0.02</x:Double>
            <x:Double x:Key="AcrylicTintOpacity">0.25</x:Double>
            <x:Double x:Key="AcrylicInactiveTintOpacity">0.55</x:Double>
            
            <SolidColorBrush x:Key="RootBackdropBrush" Color="#00000000" />
            <SolidColorBrush x:Key="ContainerBackgroundBrush" Color="#CC181818" />
            <SolidColorBrush x:Key="ContainerBorderBrush" Color="#55FFFFFF" />
            
            <!-- 卡片配色 -->
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#EE242424" />
            <SolidColorBrush x:Key="TitleBackgroundBrush" Color="#FF272727" />
            <SolidColorBrush x:Key="TitleHoverBackgroundBrush" Color="#FF323232" />
            <SolidColorBrush x:Key="TitlePressedBackgroundBrush" Color="#FF222222" />
            <SolidColorBrush x:Key="TitleGrabbedBackgroundBrush" Color="#FF1F1F1F" />
            <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#FF101010" />
            
            <!-- 文字和按钮 -->
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CCFFFFFF" />
            <SolidColorBrush x:Key="IconTextBrush" Color="#CCFFFFFF" />
            <Color x:Key="ButtonTextColor">#FFFFFFFF</Color>
            <Color x:Key="CloseButtonHoverBackgroundColor">#FFC42B1C</Color>
            <Color x:Key="CloseButtonHoverTextColor">#FFFFFFFF</Color>
            <SolidColorBrush x:Key="ButtonTextBrush" Color="{ThemeResource ButtonTextColor}" />
            <SolidColorBrush x:Key="CloseButtonHoverBackgroundBrush" Color="{ThemeResource CloseButtonHoverBackgroundColor}" />
            <SolidColorBrush x:Key="CloseButtonHoverTextBrush" Color="{ThemeResource CloseButtonHoverTextColor}" />
            
            <!-- 选区焦点框 -->
            <SolidColorBrush x:Key="FocusBorderBrush" Color="#FF4CC2FF" />
            <SolidColorBrush x:Key="FocusFillBrush" Color="#224CC2FF" />
            
            <!-- 交互遮罩层 -->
            <SolidColorBrush x:Key="CardGrabbedOverlayBrush" Color="#33000000" />
            <SolidColorBrush x:Key="CardPressedOverlayBrush" Color="#22000000" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
            <!-- 亚克力及窗口全局 -->
            <Color x:Key="AcrylicTintColor">#FFFFFFFF</Color>
            <x:Double x:Key="AcrylicBlurAmount">80</x:Double>
            <x:Double x:Key="AcrylicNoiseOpacity">0.02</x:Double>
            <x:Double x:Key="AcrylicTintOpacity">0.30</x:Double>
            <x:Double x:Key="AcrylicInactiveTintOpacity">0.60</x:Double>
            
            <SolidColorBrush x:Key="RootBackdropBrush" Color="#00000000" />
            <SolidColorBrush x:Key="ContainerBackgroundBrush" Color="#E8F3F3F3" />
            <SolidColorBrush x:Key="ContainerBorderBrush" Color="#33000000" />
            
            <!-- 卡片配色 -->
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="TitleBackgroundBrush" Color="#FFF9F9F9" />
            <SolidColorBrush x:Key="TitleHoverBackgroundBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="TitlePressedBackgroundBrush" Color="#FFF0F0F0" />
            <SolidColorBrush x:Key="TitleGrabbedBackgroundBrush" Color="#FFE8E8E8" />
            <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#FFF5F5F5" />
            
            <!-- 文字和按钮 -->
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#E8121212" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#99202020" />
            <SolidColorBrush x:Key="IconTextBrush" Color="#CC202020" />
            <Color x:Key="ButtonTextColor">#FF000000</Color>
            <Color x:Key="CloseButtonHoverBackgroundColor">#FFC42B1C</Color>
            <Color x:Key="CloseButtonHoverTextColor">#FFFFFFFF</Color>
            <SolidColorBrush x:Key="ButtonTextBrush" Color="{ThemeResource ButtonTextColor}" />
            <SolidColorBrush x:Key="CloseButtonHoverBackgroundBrush" Color="{ThemeResource CloseButtonHoverBackgroundColor}" />
            <SolidColorBrush x:Key="CloseButtonHoverTextBrush" Color="{ThemeResource CloseButtonHoverTextColor}" />
            
            <!-- 选区焦点框 -->
            <SolidColorBrush x:Key="FocusBorderBrush" Color="#FF0078D4" />
            <SolidColorBrush x:Key="FocusFillBrush" Color="#220078D4" />
            
            <!-- 交互遮罩层 -->
            <SolidColorBrush x:Key="CardGrabbedOverlayBrush" Color="#33000000" />
            <SolidColorBrush x:Key="CardPressedOverlayBrush" Color="#22000000" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
