    "version": "0.2.0",
    "configurations": [
        {
            "name": "(Windows) 启动",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${command:cmake.launchTargetDirectory}",
            "environment": [],
            "console": "internalConsole"
        },
        {
            "type": "lldb-dap",
            "request": "launch",
            "name": "Debug (CMake Target)",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "env": {
                "LLDB_USE_NATIVE_PDB_READER": "1"
            },
            "postRunCommands": [
                "breakpoint set -n _CxxThrowException",
                "breakpoint set -n __cxa_throw"
            ],
            "cwd": "${command:cmake.launchTargetDirectory}"
        }
    ]
}